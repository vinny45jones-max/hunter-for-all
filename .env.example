# === Telegram ===
TELEGRAM_BOT_TOKEN=              # Получить у @BotFather
TELEGRAM_CHAT_ID=                # Получить у @userinfobot

# === Claude API ===
ANTHROPIC_API_KEY=               # https://console.anthropic.com

# === rabota.by (можно задать позже через бота) ===
RABOTA_EMAIL=
RABOTA_PASSWORD=

# === Профиль кандидата ===
CANDIDATE_PROFILE_PATH=profile.yml  # Генерируется ботом при загрузке резюме

# === Поиск (ключевые слова извлекаются из резюме) ===
SEARCH_QUERIES=                  # Через запятую. Если пусто — бот попросит загрузить резюме
SEARCH_CITY=Минск
SEARCH_AREA_ID=16                # 16=Минск, 1002=Беларусь
MIN_RELEVANCE_SCORE=50
SCRAPE_INTERVAL_MINUTES=30
MAX_PAGES=1

# === Мониторинг сообщений ===
MESSAGE_CHECK_INTERVAL_MINUTES=5

# === Лимиты ===
MAX_APPLIES_PER_DAY=10

# === Пути (Railway Volume = /data) ===
DB_PATH=/data/hunter.db
SESSION_PATH=/data/rabota_session.json
